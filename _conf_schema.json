{
  "feeds": {
    "description": "RSS 源配置列表",
    "type": "template_list",
    "items": {
      "id": {
        "description": "Feed 唯一 ID",
        "type": "string"
      },
      "url": {
        "description": "RSS/Atom 源地址",
        "type": "string"
      },
      "auth_mode": {
        "description": "鉴权模式：none/query/header",
        "type": "string",
        "default": "none"
      },
      "key": {
        "description": "query/header 使用的鉴权密钥",
        "type": "string",
        "default": ""
      },
      "enabled": {
        "description": "是否启用该 Feed",
        "type": "bool",
        "default": true
      },
      "timeout": {
        "description": "请求超时时间（秒）",
        "type": "int",
        "default": 10
      }
    }
  },
  "targets": {
    "description": "推送目标配置列表",
    "type": "template_list",
    "items": {
      "id": {
        "description": "目标唯一 ID",
        "type": "string"
      },
      "platform": {
        "description": "平台标识，如 qq/telegram",
        "type": "string"
      },
      "unified_msg_origin": {
        "description": "AstrBot 统一会话标识",
        "type": "string",
        "default": ""
      },
      "enabled": {
        "description": "是否启用该 Target",
        "type": "bool",
        "default": true
      }
    }
  },
  "jobs": {
    "description": "订阅任务配置列表",
    "type": "template_list",
    "items": {
      "id": {
        "description": "任务唯一 ID",
        "type": "string"
      },
      "feed_ids": {
        "description": "任务绑定的 feed ID 列表",
        "type": "list",
        "items": {
          "type": "string"
        }
      },
      "target_ids": {
        "description": "任务绑定的 target ID 列表",
        "type": "list",
        "items": {
          "type": "string"
        }
      },
      "cron": {
        "description": "cron 表达式（当前版本回退到 interval）",
        "type": "string",
        "default": ""
      },
      "interval_seconds": {
        "description": "轮询间隔秒数",
        "type": "int",
        "default": 300
      },
      "batch_size": {
        "description": "单次最多推送条数",
        "type": "int",
        "default": 10
      },
      "enabled": {
        "description": "是否启用该任务",
        "type": "bool",
        "default": true
      }
    }
  },
  "llm_enabled": {
    "description": "是否启用 LLM 处理摘要/翻译",
    "type": "bool",
    "default": false
  },
  "llm_profile": {
    "description": "LLM 调用使用的 profile 名称",
    "type": "string",
    "default": "rss_enrich"
  },
  "max_input_chars": {
    "description": "发送给 LLM 的最大输入字符数",
    "type": "int",
    "default": 2000
  },
  "timeout": {
    "description": "LLM 调用超时时间（秒）",
    "type": "int",
    "default": 15
  },
  "render_mode": {
    "description": "消息渲染模式：text/image",
    "type": "string",
    "default": "text"
  },
  "summary_max_chars": {
    "description": "摘要最大长度",
    "type": "int",
    "default": 280
  },
  "render_card_template": {
    "description": "图卡/文本渲染模板字段",
    "type": "object",
    "items": {
      "title": {
        "description": "标题模板",
        "type": "string",
        "default": "{title}"
      },
      "source": {
        "description": "来源模板",
        "type": "string",
        "default": "{source}"
      },
      "published_at": {
        "description": "时间模板",
        "type": "string",
        "default": "{published_at}"
      },
      "summary": {
        "description": "摘要模板",
        "type": "string",
        "default": "{summary}"
      },
      "link_text": {
        "description": "链接文本模板",
        "type": "string",
        "default": "查看全文"
      }
    }
  }
}
